# Environment Configuration Example

# 应用设置
APP_ENV=development
PROJECT_NAME="项目名称"
VERSION=1.0.0
DESCRIPTION="项目介绍"
DEBUG=true

# API 设置
API_V1_STR=/api/v1

# CORS 设置
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000"

# Langfuse 设置
LANGFUSE_SECRET_KEY="<Langfuse Secret Key>"
LANGFUSE_PUBLIC_KEY="<Langfuse Public Key>"
LANGFUSE_BASE_URL="<Langfuse Base URL>"

# LLM 模型设置
OPENAI_API_KEY="<OpenAI API Key>" 
DEFAULT_LLM_MODEL=gpt-5-mini
DEFAULT_LLM_TEMPERATURE=0.2
# qwen模型设置
DASHSCOPE_API_KEY="<Dashscope API Key>"
DASHSCOPE_API_BASE="https://dashscope.aliyuncs.com/compatible-mode/v1"
DASHSCOPE_DEFAULT_LLM_MODEL=qwen3.5-flash

# JWT 设置
JWT_SECRET_KEY="<JWT Secret Key>"
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=30

# 数据库设置
# POSTGRES_HOST之后再修改
POSTGRES_HOST="<PostgreSQL Host>"
POSTGRES_DB="<PostgreSQL Database>"
POSTGRES_USER="<PostgreSQL User>"
POSTGRES_PORT="<PostgreSQL Port>"
POSTGRES_PASSWORD="<PostgreSQL Password>"
POSTGRES_POOL_SIZE="<PostgreSQL Pool Size>"
POSTGRES_MAX_OVERFLOW="<PostgreSQL Max Overflow>"

# 这些设置之后再看
# Rate Limiting Settings
RATE_LIMIT_DEFAULT="1000 per day,200 per hour"
RATE_LIMIT_CHAT="100 per minute"
RATE_LIMIT_CHAT_STREAM="100 per minute"
RATE_LIMIT_MESSAGES="200 per minute"
RATE_LIMIT_LOGIN="100 per minute"

# 日志设置
LOG_LEVEL=INFO
LOG_FORMAT=console
LOG_DIR=../projectlogs

# 第三方API的KEY
QWEATHER_API_KEY="<QWeather API Key>"
QWEATHER_API_HOST="<QWeather API Host>"

# 高德地图API配置
AMAP_API_KEY="<AMAP API Key>"
VITE_AMAP_WEB_JS_KEY="<VITE_AMAP_WEB_JS_KEY>"
